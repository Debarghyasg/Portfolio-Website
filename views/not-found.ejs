<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/background") %>

  <div class="page-shell">
    <%- include("navbar") %>

    <main>
      <section class="container notfound">
        <div class="notfound-code reveal">404</div>
        <h2 class="section-heading reveal delay-1" style="font-size: clamp(1.6rem, 4vw, 2.4rem);">
          Page not found
        </h2>
        <p class="section-subhead reveal delay-2" style="text-align:center;">
          The page you're looking for doesn't exist or has moved.
        </p>
        <div class="reveal delay-3" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
          <a class="btn btn-primary" href="/">Back home</a>
          <button type="button" class="btn btn-secondary" data-cmdk-open>Search the site</button>
        </div>
      </section>
    </main>

    <%- include("footer") %>
  </div>

  <%- include("partials/cmdk") %>
  <%- include("partials/scripts") %>
</body>
</html>
