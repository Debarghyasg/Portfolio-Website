<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/background") %>

  <div class="page-shell">
    <%- include("navbar") %>

    <main>
      <%
        const DEVICONS = "https://cdn.jsdelivr.net/gh/devicons/devicon/icons";

        // Inline SVG fallbacks for items devicon doesn't have or where a
        // generic icon reads better than a busy logo.
        const FALLBACK_SVGS = {
          arrays: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="16" width="18" height="4" rx="1"/></svg>',
          string: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>',
          link: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
          tree: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="4" r="2"/><circle cx="6" cy="14" r="2"/><circle cx="18" cy="14" r="2"/><circle cx="3" cy="20" r="1.5"/><circle cx="9" cy="20" r="1.5"/><circle cx="15" cy="20" r="1.5"/><circle cx="21" cy="20" r="1.5"/><path d="M12 6v2L6 12M12 6v2l6 4M6 16l-3 3M6 16l3 3M18 16l-3 3M18 16l3 3"/></svg>',
          graph: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="12" cy="13" r="2"/><circle cx="6" cy="20" r="2"/><circle cx="18" cy="20" r="2"/><path d="M6.6 7.4 11 11.4M17.4 7.4 13 11.4M11 14.5 7 18.5M13 14.5l4 4"/></svg>',
          template: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
          shield: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
        };

        const techStack = [
          {
            id: "languages",
            title: "Languages",
            items: [
              { name: "Java",        iconUrl: `${DEVICONS}/java/java-original.svg` },
              { name: "JavaScript",  iconUrl: `${DEVICONS}/javascript/javascript-original.svg` },
              { name: "HTML5",       iconUrl: `${DEVICONS}/html5/html5-original.svg` },
              { name: "CSS3",        iconUrl: `${DEVICONS}/css3/css3-original.svg` },
              { name: "Python",      iconUrl: `${DEVICONS}/python/python-original.svg` },
              { name: "C",           iconUrl: `${DEVICONS}/c/c-original.svg` },
            ],
          },
          {
            id: "frontend",
            title: "Frontend",
            items: [
              { name: "React",   iconUrl: `${DEVICONS}/react/react-original.svg` },
              { name: "HTML5",   iconUrl: `${DEVICONS}/html5/html5-original.svg` },
              { name: "CSS3",    iconUrl: `${DEVICONS}/css3/css3-original.svg` },
              { name: "Bootstrap", iconUrl: `${DEVICONS}/bootstrap/bootstrap-original.svg` },
            ],
          },
          {
            id: "backend",
            title: "Backend",
            items: [
              { name: "Node.js",     iconUrl: `${DEVICONS}/nodejs/nodejs-original.svg` },
              { name: "Express.js",  iconUrl: `${DEVICONS}/express/express-original.svg`, invertInDark: true },
              { name: "EJS",         svgId: "template" },
              { name: "REST APIs",   svgId: "shield" },
            ],
          },
          {
            id: "databases",
            title: "Databases",
            items: [
              { name: "MySQL",      iconUrl: `${DEVICONS}/mysql/mysql-original.svg` },
              { name: "MongoDB",    iconUrl: `${DEVICONS}/mongodb/mongodb-original.svg` },
              { name: "PostgreSQL", iconUrl: `${DEVICONS}/postgresql/postgresql-original.svg` },
            ],
          },
          {
            id: "cloud",
            title: "Cloud Platforms",
            items: [
              { name: "AWS",             iconUrl: `${DEVICONS}/amazonwebservices/amazonwebservices-original-wordmark.svg`, invertInDark: true },
              { name: "Microsoft Azure", iconUrl: `${DEVICONS}/azure/azure-original.svg` },
              { name: "Oracle Cloud",    iconUrl: `${DEVICONS}/oracle/oracle-original.svg` },
            ],
          },
          {
            id: "devops",
            title: "DevOps & Tools",
            items: [
              { name: "Git",        iconUrl: `${DEVICONS}/git/git-original.svg` },
              { name: "GitHub",     iconUrl: `${DEVICONS}/github/github-original.svg`, invertInDark: true },
              { name: "Docker",     iconUrl: `${DEVICONS}/docker/docker-original.svg` },
              { name: "Kubernetes", iconUrl: `${DEVICONS}/kubernetes/kubernetes-plain.svg` },
              { name: "npm",        iconUrl: `${DEVICONS}/npm/npm-original-wordmark.svg` },
              { name: "VS Code",    iconUrl: `${DEVICONS}/vscode/vscode-original.svg` },
            ],
          },
          {
            id: "dsa",
            title: "DSA Foundations",
            items: [
              { name: "Java",        iconUrl: `${DEVICONS}/java/java-original.svg` },
              { name: "Arrays",      svgId: "arrays" },
              { name: "Strings",     svgId: "string" },
              { name: "Linked Lists", svgId: "link" },
              { name: "Trees",       svgId: "tree", muted: true },
              { name: "Graphs",      svgId: "graph", muted: true },
            ],
          },
        ];
      %>

      <section class="container hero">
        <div class="reveal">
          <span class="section-eyebrow">Toolkit</span>
        </div>
        <h1 class="section-heading reveal delay-1" style="font-size: clamp(2.6rem, 6vw, 4.2rem);">
          Tech Stack
        </h1>
        <p class="section-subhead reveal delay-2">
          Tools I build with — languages, frameworks, databases, cloud platforms,
          and the everyday tools that hold it all together.
        </p>
      </section>

      <section class="container section">
        <div class="techstack-grid">
          <% techStack.forEach((cat, i) => { %>
            <article class="glass-card is-hoverable techstack-card reveal <%= ['', 'delay-1', 'delay-2', 'delay-3', 'delay-4'][i % 5] %>" id="<%= cat.id %>">
              <h3 class="cat-title">
                <span class="slash">//</span><span><%= cat.title %></span>
              </h3>
              <div class="chip-row">
                <% cat.items.forEach(item => { %>
                  <span class="tech-chip-v2" title="<%= item.name %>">
                    <% if (item.iconUrl) { %>
                      <img
                        src="<%= item.iconUrl %>"
                        alt=""
                        class="<%= item.invertInDark ? 'invert-dark' : '' %>"
                        width="18"
                        height="18"
                        loading="lazy"
                      />
                    <% } else if (item.svgId && FALLBACK_SVGS[item.svgId]) { %>
                      <span class="svg-fallback" aria-hidden="true">
                        <%- FALLBACK_SVGS[item.svgId] %>
                      </span>
                    <% } %>
                    <span><%= item.name %><% if (item.muted) { %> <small style="color:var(--muted-2);font-size:0.72rem;">· up next</small><% } %></span>
                  </span>
                <% }) %>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="container section">
        <div class="section-head reveal">
          <span class="section-eyebrow">Currently learning</span>
          <h2 class="section-heading">What I'm doubling down on</h2>
          <p class="section-subhead">
            Building deeper expertise in the areas closest to where I want to work next.
          </p>
        </div>

        <div class="card-grid cols-3">
          <article class="glass-card is-hoverable reveal">
            <div class="card-body">
              <h3 style="font-size:1.05rem;font-weight:500;letter-spacing:-0.02em;">Java with DSA</h3>
              <p style="margin-top:8px;font-size:0.92rem;">
                Daily problem-solving on arrays, strings and linked lists. Trees and graphs are next.
              </p>
            </div>
          </article>
          <article class="glass-card is-hoverable reveal delay-1">
            <div class="card-body">
              <h3 style="font-size:1.05rem;font-weight:500;letter-spacing:-0.02em;">Cloud Computing</h3>
              <p style="margin-top:8px;font-size:0.92rem;">
                Deepening Azure and OCI skills as MSA Cloud Lead — from IAM to deployment pipelines.
              </p>
            </div>
          </article>
          <article class="glass-card is-hoverable reveal delay-2">
            <div class="card-body">
              <h3 style="font-size:1.05rem;font-weight:500;letter-spacing:-0.02em;">Applied AI</h3>
              <p style="margin-top:8px;font-size:0.92rem;">
                Building real things with LLMs and CNNs — RAG, fraud detection, and crop diagnosis.
              </p>
            </div>
          </article>
        </div>
      </section>
    </main>

    <%- include("footer") %>
  </div>

  <%- include("partials/cmdk") %>
  <%- include("partials/scripts") %>
</body>
</html>
