<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/background") %>

  <div class="page-shell">
    <%- include("navbar") %>

    <main>
      <%
        // ---- helper: turn any YouTube URL into an autoplay+mute embed URL ----
        const DEVICONS = "https://cdn.jsdelivr.net/gh/devicons/devicon/icons";

        // ---- helper: pick a tech icon for a tag string ----
        // Returns { url, invertDark? } for devicon-hosted icons, or
        // { svg } with inline SVG markup for items devicon doesn't have.
        // Order matters — most-specific keywords first.
        function iconForTag(tag) {
          const t = (tag || "").toLowerCase();
          if (t.includes("react"))   return { url: `${DEVICONS}/react/react-original.svg` };
          if (t.includes("vite"))    return { url: `${DEVICONS}/vitejs/vitejs-original.svg` };
          if (t.includes("node"))    return { url: `${DEVICONS}/nodejs/nodejs-original.svg` };
          if (t.includes("express")) return { url: `${DEVICONS}/express/express-original.svg`, invertDark: true };
          if (t.includes("fastapi")) return { url: `${DEVICONS}/fastapi/fastapi-original.svg` };
          if (t.includes("python"))  return { url: `${DEVICONS}/python/python-original.svg` };
          if (t.includes("flask"))   return { url: `${DEVICONS}/flask/flask-original.svg`, invertDark: true };
          if (t.includes("tensorflow") || t.includes("keras"))
                                     return { url: `${DEVICONS}/tensorflow/tensorflow-original.svg` };
          if (t === "html" || t.startsWith("html"))
                                     return { url: `${DEVICONS}/html5/html5-original.svg` };
          if (t === "css" || t.startsWith("css"))
                                     return { url: `${DEVICONS}/css3/css3-original.svg` };
          if (t === "javascript")    return { url: `${DEVICONS}/javascript/javascript-original.svg` };
          if (t.includes("bootstrap")) return { url: `${DEVICONS}/bootstrap/bootstrap-original.svg` };
          if (t.includes("redis"))   return { url: `${DEVICONS}/redis/redis-original.svg` };
          if (t.includes("postgresql")) return { url: `${DEVICONS}/postgresql/postgresql-original.svg` };
          if (t.includes("mongodb")) return { url: `${DEVICONS}/mongodb/mongodb-original.svg` };
          if (t.includes("mysql"))   return { url: `${DEVICONS}/mysql/mysql-original.svg` };
          if (t.includes("oracle"))  return { url: `${DEVICONS}/oracle/oracle-original.svg` };
          if (t.includes("azure"))   return { url: `${DEVICONS}/azure/azure-original.svg` };
          if (t.includes("aws") || t.includes("amazon"))
                                     return { url: `${DEVICONS}/amazonwebservices/amazonwebservices-original-wordmark.svg`, invertDark: true };

          // Inline-SVG fallbacks for items devicon doesn't have
          if (t === "ejs")
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>' };
          if (t.includes("chroma") || t.includes("database"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>' };
          if (t.includes("websocket"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>' };
          if (t.includes("cron"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' };
          if (t.includes("yolo") || t.includes("ocr"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/></svg>' };
          if (t.includes("cnn"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="6" r="2"/><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><circle cx="12" cy="18" r="2"/><path d="M12 8v8M8 12h8"/></svg>' };
          if (t.includes("groq") || t.includes("llama"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="14" x2="22" y2="14"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="14" x2="4" y2="14"/></svg>' };
          if (t.includes("huggingface") || t.includes("minilm") || t.includes("transformer") || t.includes("sentence"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>' };
          if (t.includes("bm25") || t.includes("rank"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>' };
          if (t.includes("clerk") || t.includes("oauth"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>' };
          if (t.includes("smtp") || t.includes("gmail") || t.includes("mail"))
            return { svg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>' };

          return null;
        }

        function isYouTube(url) {
          return /youtube\.com|youtu\.be/.test(url);
        }
        function youTubeEmbedUrl(url) {
          let id = "";
          const m1 = url.match(/youtube\.com\/embed\/([^?&]+)/);
          const m2 = url.match(/[?&]v=([^&]+)/);
          const m3 = url.match(/youtu\.be\/([^?&]+)/);
          if (m1) id = m1[1];
          else if (m2) id = m2[1];
          else if (m3) id = m3[1];
          if (!id) return url;
          return `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&modestbranding=1&rel=0&playsinline=1`;
        }

        // ---- project data (drop a videoUrl into any project to enable a demo) ----
        const projects = [
          {
            id: "nyatik-nayan",
            title: "Nyatik Nayan",
            tagline: "Scan Smart. Sell Safe.",
            description:
              "An AI-powered fraud detection and checkout management platform that verifies every product scan in under a second, flags suspicious transactions instantly, and explains exactly why something looks fraudulent — so retailers can act before the damage is done.",
            tags: [
              "React 19", "Vite 8", "Node.js", "Express 5", "FastAPI",
              "YOLOv8/v10", "EasyOCR", "Groq", "Llama 3.1", "Redis",
              "PostgreSQL", "WebSocket", "node-cron",
            ],
            note: "See README for full tech stack.",
            sourceUrl: "https://github.com/Debarghyasg/Nyatik-Nayan",
            videoUrl: "https://youtu.be/8uflHoaGNuY",
          },
          {
            id: "fin-eye",
            title: "Fin-Sight",
            tagline: "Ask your financial documents anything.",
            description:
              "A production-grade RAG platform for financial intelligence. Upload 10-Ks, earnings calls and annual reports, then ask in plain English — get cited answers with page numbers and confidence scores. No hallucinations, just answers you can trust.",
            tags: [
              "Groq (Llama 3.1 70B)", "HuggingFace MiniLM",
              "rank-bm25", "Redis", "PostgreSQL 16", "FastAPI", "Clerk",
              "sentence-transformers",
            ],
            note: "See README for full tech stack.",
            sourceUrl: "https://github.com/Debarghyasg/Fin-Sight",
            videoUrl: "https://youtu.be/PE4CrusqRfg",
          },
          {
            id: "medi-hub",
            title: "Medi-Hub",
            tagline: "Bridging paper records and digital health.",
            description:
              "MediHub is a full-stack web application that turns cluttered paper prescriptions into structured, searchable digital history while ensuring users never miss a follow-up consultation.",
            tags: ["HTML", "CSS", "JavaScript", "EJS", "Bootstrap", "Python"],
            note: "See README for full tech stack.",
            sourceUrl: "https://github.com/Debarghyasg/Medi-Hub",
            videoUrl: "https://youtu.be/3bz-BAL5ZOM",
          },
          {
            id: "potatoscan",
            title: "PotatoScan",
            tagline: "AI-powered autonomous tuber protection.",
            description:
              "Snap a photo of a potato leaf and get an instant disease diagnosis with 97% accuracy, treatment recommendations, and multilingual support (EN/HI/BN). No lab. No agronomist. No waiting.",
            tags: [
              "TensorFlow / Keras", "CNN", "Node.js", "Flask",
              "PostgreSQL", "Google OAuth", "Gmail SMTP",
            ],
            note: "Detects 7 disease classes with full dashboard, scan history & 3 free trial scans.",
            sourceUrl: "https://github.com/Debarghyasg/Potato-Leaf-Disease-prediction",
            videoUrl: "https://youtu.be/tPWcY2UZ1UE",
          },
          {
            id: "mahakash",
            title: "Mahakash Club Website",
            tagline: "The official site for GNIT's space club.",
            description:
              "Showcases the club's activities, events and space-related content to engage and inform members and visitors.",
            tags: ["HTML", "CSS", "JavaScript", "Node.js", "EJS", "Bootstrap"],
            sourceUrl: "https://mahakash-club.vercel.app/",
            liveUrl: "https://mahakash-club.vercel.app/",
          },
          {
            id: "portfolio",
            title: "Portfolio Website",
            tagline: "This site — designed for the next iteration.",
            description:
              "A personal portfolio showcasing my skills, projects and experience in a professional and visually expressive way.",
            tags: ["React.js", "HTML", "CSS", "JavaScript", "Node.js", "EJS"],
            sourceUrl: "https://github.com/Debarghyasg/Portfolio-Website",
            liveUrl: "https://debarghyasg.vercel.app/",
          },
        ];
      %>

      <section class="container hero">
        <div class="reveal">
          <span class="section-eyebrow">Work</span>
        </div>
        <h1 class="section-heading reveal delay-1" style="font-size: clamp(2.6rem, 6vw, 4.2rem);">
          My Projects
        </h1>
        <p class="section-subhead reveal delay-2">
          A selection of recent work across AI, cloud, and full-stack web. Toggle the
          <strong>Demo</strong> button on any card to play a walkthrough video right inside
          the card.
        </p>
      </section>

      <section class="container section">
        <div class="card-grid cols-2">
          <% projects.forEach((p, i) => { %>
            <article class="glass-card is-hoverable project-card reveal <%= i % 2 ? 'delay-1' : '' %>"
                     id="project-<%= p.id %>">
              <div class="card-body">

                <header class="card-header">
                  <div>
                    <h3><%= p.title %></h3>
                    <p class="project-tagline mt-12"><%= p.tagline %></p>
                  </div>
                  <div class="header-actions">
                    <% if (p.videoUrl) { %>
                      <button type="button"
                              class="btn-pill is-active"
                              data-toggle-video="<%= p.id %>"
                              aria-pressed="true"
                              aria-controls="video-<%= p.id %>"
                              aria-label="Toggle demo video">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M23 7l-7 5 7 5V7z" />
                          <rect x="1" y="5" width="15" height="14" rx="2" />
                        </svg>
                        <span class="btn-label">Demo</span>
                      </button>
                    <% } %>
                    <a class="btn-pill" href="<%= p.sourceUrl %>" target="_blank" rel="noopener" aria-label="<%= p.title %> source">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 .3a12 12 0 0 0-3.79 23.4c.6.1.82-.26.82-.58 0-.28 0-1.04-.02-2.04-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.08-.74.09-.73.09-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.34-5.47-5.94 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.4s2.04.13 3 .4c2.3-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22 0 1.6-.01 2.9-.01 3.29 0 .32.21.7.83.58A12 12 0 0 0 12 .3"/>
                      </svg>
                      <span class="btn-label">Source</span>
                    </a>
                    <% if (p.liveUrl) { %>
                      <a class="btn-pill" href="<%= p.liveUrl %>" target="_blank" rel="noopener" aria-label="<%= p.title %> live">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                          <polyline points="15 3 21 3 21 9"/>
                          <line x1="10" y1="14" x2="21" y2="3"/>
                        </svg>
                        <span class="btn-label">Live</span>
                      </a>
                    <% } %>
                  </div>
                </header>

                <% if (p.videoUrl) { %>
                  <div class="video-container"
                       id="video-<%= p.id %>"
                       data-video-for="<%= p.id %>"
                       data-video-url="<%= p.videoUrl %>"
                       data-video-embed-url="<%= isYouTube(p.videoUrl) ? youTubeEmbedUrl(p.videoUrl) : p.videoUrl %>"
                       data-video-type="<%= isYouTube(p.videoUrl) ? 'youtube' : 'file' %>">
                    <% if (isYouTube(p.videoUrl)) { %>
                      <iframe
                        src="<%= youTubeEmbedUrl(p.videoUrl) %>"
                        allow="autoplay; encrypted-media"
                        allowfullscreen
                        title="<%= p.title %> demo video"
                        loading="lazy"></iframe>
                    <% } else { %>
                      <video
                        src="<%= p.videoUrl %>"
                        autoplay
                        muted
                        loop
                        playsinline
                        preload="metadata"></video>
                    <% } %>
                  </div>
                <% } %>

                <p class="project-desc"><%= p.description %></p>

                <div class="tag-row">
                  <% p.tags.forEach(t => {
                    const ic = iconForTag(t);
                  %>
                    <span class="tag-pill"><%
                      if (ic && ic.url) { %><img src="<%= ic.url %>" alt="" class="<%= ic.invertDark ? 'invert-dark' : '' %>" loading="lazy" /><%
                      } else if (ic && ic.svg) { %><%- ic.svg %><%
                      } %><span><%= t %></span></span>
                  <% }) %>
                </div>

                <% if (p.note) { %>
                  <p class="note">⚠ <%= p.note %></p>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>

        <p class="section-subhead reveal" style="margin-top:48px;text-align:center;">
          More projects coming soon — adding video walkthroughs as I record them.
        </p>
      </section>
    </main>

    <%- include("footer") %>
  </div>

  <%- include("partials/cmdk") %>
  <%- include("partials/scripts") %>
</body>
</html>
