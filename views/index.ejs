<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/background") %>

  <div class="page-shell">
    <%- include("navbar") %>

    <main>
      <!-- ===== Hero ===== -->
      <section class="container hero">
        <div class="hero-grid">
          <div>
            <span class="section-eyebrow reveal">// engineer</span>
            <%
              // Edit this list to change the rotating tagline under the name.
              const TYPEWRITER_WORDS = [
                "Final-year CSE @ GNIT, Kolkata.",
                "RAG. CI/CD. Cloud at scale.",
                "Cloud Computing Lead, MSA GNIT.",
                "Co-Head of Mahakash Club.",
                "Complexity, met with precision."
              ];
            %>
            <h1 class="reveal delay-1 mt-12">
              Hi, I'm <span class="gradient-text">Debarghya Sengupta</span><br />
              <span class="typewriter" data-words='<%= JSON.stringify(TYPEWRITER_WORDS) %>'>
                <span class="tw-text"><%= TYPEWRITER_WORDS[0] %></span><span class="tw-cursor" aria-hidden="true">|</span>
              </span>
            </h1>
            <p class="hero-lede reveal delay-2">
              I'm a Final year CSE student who doesn't just write code — I architect it. Clean APIs,
              efficient data flows, systems that hold under pressure. My sweet spot
              lives where complexity meets precision: RAG pipelines, CI/CD workflows,
              and cloud infrastructure that doesn't flinch at scale.
            </p>
            <div class="hero-cta reveal delay-3">
              <a href="/resume.pdf" target="_blank" rel="noopener" class="btn btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                View Resume
              </a>
              <a href="/projects" class="btn btn-secondary">
                See projects
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </a>
              <button type="button" class="btn btn-ghost" data-copy-email="debarghya817@gmail.com">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="m22 7-10 6L2 7" />
                </svg>
                Copy email
              </button>
            </div>

            <!-- Stat row / quick links -->
            <div class="stat-row reveal delay-4">
              <a href="https://github.com/Debarghyasg" target="_blank" rel="noopener">
                <div class="stat-value">GitHub</div>
                <div class="stat-label">@Debarghyasg</div>
              </a>
              <a href="https://www.linkedin.com/in/debarghya-sengupta-890863168/" target="_blank" rel="noopener">
                <div class="stat-value">LinkedIn</div>
                <div class="stat-label">Let's connect</div>
              </a>
              <a href="/projects">
                <div class="stat-value">7+</div>
                <div class="stat-label">Projects shipped</div>
              </a>
            </div>
          </div>

          <div class="hero-photo-wrap reveal delay-2">
            <div class="hero-photo-glow" aria-hidden="true"></div>
            <img class="hero-photo" src="/me2.jpg" alt="Debarghya Sengupta" />
          </div>
        </div>
      </section>

      <!-- ===== About Me — story-style with expand-to-modal ===== -->
      <section class="container section about-section" id="about">
        <div class="section-head reveal">
          <span class="section-eyebrow">// about me</span>
          <h2 class="section-heading">The Story So Far</h2>
          <p class="section-subhead">
            Cleaner code. Sharper systems. Fewer rough edges. That's the job.
          </p>
        </div>

        <div class="story-grid">
          <div class="story-text reveal">
            <p>
              I'm an <strong>CSE Student</strong> who doesn't just write code — I architect it.
              Clean APIs, efficient data flows, systems that hold under pressure.
              If there's a bug, an inconsistency, or a rough edge anywhere in the stack,
              it doesn't stay that way for long. <strong>I find it. I own it. I fix it — properly.</strong>
            </p>
            <p>
              My sweet spot lives where complexity meets precision: <em>RAG pipelines</em>,
              <em>CI/CD workflows</em>, and cloud infrastructure that doesn't flinch at scale.
              The kind of work where cutting corners isn't a shortcut — it's a liability.
            </p>
            <p>
              The only flaw you'll find in my code? <em>I aimed for perfection and got
              too close to stop.</em>
            </p>

            <div class="tag-row mt-24">
              <span class="tag-pill">Kolkata, India</span>
              <span class="tag-pill">Final-Year CSE @ GNIT</span>
              <span class="tag-pill">Graduating 2027</span>
              <span class="tag-pill">Open to opportunities</span>
            </div>

            <div class="story-actions mt-24">
              <button type="button" class="btn btn-aurora" data-expand-about>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="15 3 21 3 21 9"/>
                  <polyline points="9 21 3 21 3 15"/>
                  <line x1="21" y1="3" x2="14" y2="10"/>
                  <line x1="3" y1="21" x2="10" y2="14"/>
                </svg>
                Expand the full story
              </button>
            </div>
          </div>

          <aside class="story-timeline reveal delay-1">
            <h3 class="timeline-title">// the evolution</h3>
            <div class="timeline-list">
              <div class="timeline-year">
                <span class="year-label">2026</span>
                <ul class="year-items">
                  <li>Building AI projects (Nyatik Nayan, Fin-Eye); leading MSA Cloud.</li>
                  <li>Going deeper on Java DSA — trees and graphs are next.</li>
                </ul>
              </div>
              <div class="timeline-year">
                <span class="year-label">2025</span>
                <ul class="year-items">
                  <li>Co-Head of Mahakash; multiple Oracle &amp; Microsoft certifications.</li>
                  <li>Shipped MediHub and PotatoScan.</li>
                </ul>
              </div>
              <div class="timeline-year">
                <span class="year-label">2024</span>
                <ul class="year-items">
                  <li>First real full-stack projects with React, Node and Express.</li>
                  <li>Designed and shipped the Mahakash Club website.</li>
                </ul>
              </div>
              <div class="timeline-year">
                <span class="year-label">2023</span>
                <ul class="year-items">
                  <li>Entered GNIT for Computer Science Engineering.</li>
                  <li>Wrote my first programs in Java, Python and C.</li>
                </ul>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <!-- ===== GitHub Activity — heatmap + activity line graph ===== -->
      <section class="container section" id="github">
        <div class="section-head reveal">
          <span class="section-eyebrow">// my activity</span>
          <h2 class="section-heading">GitHub Activity</h2>
          <p class="section-subhead">
            Last 6 months of contributions on the left, last 31 days of commit
            activity on the right.
          </p>
        </div>

        <div class="card-grid cols-2 github-grid">
          <!-- LEFT: contribution heatmap -->
          <article class="glass-card reveal">
            <div class="card-body">
              <h3 class="github-card-title">
                <span class="dot" aria-hidden="true"></span>Contributions
                <span class="github-card-sub">last 6 months</span>
              </h3>
              <div class="github-graph-card" id="github-graph" data-username="Debarghyasg">
                <div class="gg-loading">Loading the last 6 months from GitHub…</div>
              </div>
              <p class="gg-source mt-24">
                Live from
                <a href="https://github.com/Debarghyasg" target="_blank" rel="noopener">github.com/Debarghyasg</a>.
              </p>
            </div>
          </article>

          <!-- RIGHT: commit-activity line graph (external SVG) -->
          <article class="glass-card reveal delay-1">
            <div class="card-body">
              <h3 class="github-card-title">
                <span class="dot" aria-hidden="true"></span>Commit activity
                <span class="github-card-sub">last 31 days</span>
              </h3>
              <div class="activity-graph-wrap">
                <img
                  class="activity-graph-img"
                  src="https://github-readme-activity-graph.vercel.app/graph?username=Debarghyasg&bg_color=00000000&color=ffffffaa&line=39d353&point=ffffff&area=true&area_color=26a64166&hide_border=true&custom_title=Daily%20commits"
                  alt="Daily commit activity for Debarghyasg over the last 31 days"
                  loading="lazy"
                />
              </div>
              <p class="gg-source mt-24">
                Generated by
                <a href="https://github.com/Ashutosh00710/github-readme-activity-graph" target="_blank" rel="noopener">github-readme-activity-graph</a>.
              </p>
            </div>
          </article>
        </div>
      </section>

      <!-- ===== Currently Managing ===== -->
      <section class="container section" id="managing">
        <div class="section-head reveal">
          <span class="section-eyebrow">// leadership</span>
          <h2 class="section-heading">Currently Managing</h2>
          <p class="section-subhead">
            Two communities. Cloud and the cosmos. Both worth showing up for, every week.
          </p>
        </div>

        <div class="card-grid cols-2">
          <article class="glass-card is-hoverable reveal">
            <div class="card-body managing-card">
              <img class="managing-logo" src="/MSA.jpg" alt="Microsoft Student Ambassador" />
              <div>
                <div class="managing-role">Cloud Computing Lead</div>
                <h3>
                  <a class="club-link" href="https://msa-gnit-inauguration-website.vercel.app/" target="_blank" rel="noopener">
                    Microsoft Student Ambassador — GNIT Chapter
                  </a>
                </h3>
                <p>
                  As Cloud Computing Domain Lead, I promote the MSA program and help students
                  learn cloud computing fundamentals while showcasing Azure services through
                  workshops and hands-on sessions.
                </p>
                <div class="tag-row mt-24">
                  <span class="tag-pill">Microsoft Azure</span>
                  <span class="tag-pill">Cloud workshops</span>
                  <span class="tag-pill">Mentorship</span>
                </div>
              </div>
            </div>
          </article>

          <article class="glass-card is-hoverable reveal delay-1">
            <div class="card-body managing-card">
              <img class="managing-logo" src="/mahakash logo.jpg" alt="Mahakash Club" />
              <div>
                <div class="managing-role">Co-Head</div>
                <h3>
                  <a class="club-link" href="https://mahakash-club.vercel.app/" target="_blank" rel="noopener">
                    Mahakash Club — GNIT
                  </a>
                </h3>
                <p>
                  Mahakash Club is GNIT's space club, fostering curiosity in astrophysics,
                  aerospace engineering and beyond. We organise meets and seminars to spread
                  space awareness across the student community.
                </p>
                <div class="tag-row mt-24">
                  <span class="tag-pill">Astrophysics</span>
                  <span class="tag-pill">Aerospace</span>
                  <span class="tag-pill">Community</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- ===== Certificates ===== -->
      <section class="container section" id="certificates">
        <div class="section-head reveal">
          <span class="section-eyebrow">// credentials</span>
          <h2 class="section-heading">Certificates</h2>
          <p class="section-subhead">
            Verified. From Microsoft, Oracle, and Zscaler. Receipts, not vibes.
          </p>
        </div>

        <div class="card-grid cols-2">
          <%
            function issuerIcon(issuer) {
              const i = (issuer || "").toLowerCase();
              // Microsoft 4-color tile mark
              if (i.includes("microsoft")) {
                return '<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">' +
                  '<rect x="2" y="2" width="9" height="9" fill="#F25022"/>' +
                  '<rect x="13" y="2" width="9" height="9" fill="#7FBA00"/>' +
                  '<rect x="2" y="13" width="9" height="9" fill="#00A4EF"/>' +
                  '<rect x="13" y="13" width="9" height="9" fill="#FFB900"/>' +
                  '</svg>';
              }
              // Oracle red ellipse mark
              if (i.includes("oracle")) {
                return '<svg viewBox="0 0 24 24" width="24" height="22" aria-hidden="true">' +
                  '<ellipse cx="12" cy="12" rx="10.5" ry="6.5" fill="none" stroke="#C74634" stroke-width="3"/>' +
                  '</svg>';
              }
              // Zscaler — blue shield with stylised Z
              if (i.includes("zscaler")) {
                return '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#0072BB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
                  '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' +
                  '<path d="M9 9h6l-6 6h6" stroke-width="1.6"/>' +
                  '</svg>';
              }
              // Generic award fallback (current colour: amber)
              return '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
                '<circle cx="12" cy="8" r="6"/>' +
                '<path d="M9 14.5 8 22l4-2 4 2-1-7.5"/>' +
                '</svg>';
            }
            const certs = [
              { title: "Get started with Azure management tasks", issuer: "Microsoft Learn", url: "https://learn.microsoft.com/en-gb/users/debarghyasengupta-8651/credentials/74750622131f20c4?ref=https%3A%2F%2Fwww.linkedin.com%2F" },
              { title: "Oracle AI Autonomous Database 2025 Certified Professional", issuer: "Oracle", url: "https://catalog-education.oracle.com/ords/certview/sharebadge?id=591514EF20FD20BC84E336AC2819225FF26433988D10B1E6C71630806AE2C2B7" },
              { title: "Oracle Cloud Infrastructure 2025 Certified Developer Professional", issuer: "Oracle", url: "https://catalog-education.oracle.com/ords/certview/sharebadge?id=210FB9758EE5CB78DCB091A2C45E3912B9642194C67D5045B6458DD9811F8B7E" },
              { title: "OCI 2025 Certified Generative AI Professional", issuer: "Oracle", url: "https://catalog-education.oracle.com/ords/certview/sharebadge?id=7B82CA855F2E3117E86F8B1B409E5577832453A248597E50F1E20F79F7F6D70C" },
              { title: "Fundamentals of Cybersecurity", issuer: "Zscaler", url: "https://verify.skilljar.com/c/sjfwr9ry9uuv" },
            ];
          %>
          <% certs.forEach((c, i) => { %>
            <a class="glass-card is-hoverable cert-card reveal <%= i % 2 ? 'delay-1' : '' %>" href="<%= c.url %>" target="_blank" rel="noopener">
              <div class="cert-icon" aria-hidden="true">
                <%- issuerIcon(c.issuer) %>
              </div>
              <div class="cert-meta">
                <div class="cert-title"><%= c.title %></div>
                <div class="cert-issuer"><%= c.issuer %></div>
              </div>
              <span class="cert-arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7M17 7H8M17 7v9" />
                </svg>
              </span>
            </a>
          <% }) %>
        </div>
      </section>
    </main>

    <%- include("footer") %>
  </div>

  <%- include("partials/cmdk") %>
  <%- include("partials/about-modal") %>
  <%- include("partials/scripts") %>
</body>
</html>
